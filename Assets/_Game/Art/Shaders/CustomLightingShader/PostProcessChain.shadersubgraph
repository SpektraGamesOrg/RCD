    "m_SourceType": 1,
    "m_FunctionName": "Contrasteffect",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Girişler: In (Vector3), Contrast (Float)\r\n// Çıkış: Out (Vector3)\r\n\r\nfloat logcA = 5.555556;\r\nfloat logcB = 0.047996;\r\nfloat logcC = 0.244161;\r\nfloat logcD = 0.386036;\r\nfloat midGray = 0.4135884;\r\n\r\nfloat contrastAmount = Contrast * 0.01 + 1.0;\r\n\r\nfloat3 logC = logcC * log10(logcA * In + logcB) + logcD;\r\nlogC = (logC - midGray) * contrastAmount + midGray;\r\nfloat3 lin = (pow(10.0, (logC - logcD) / logcC) - logcB) / logcA;\r\n\r\nOut = max(0.0, lin);"
}

