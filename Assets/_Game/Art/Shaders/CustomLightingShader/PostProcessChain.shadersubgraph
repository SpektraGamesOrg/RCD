    "m_SourceType": 1,
    "m_FunctionName": "ApplyLUT",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Girişler: In (Vector3, [0,1]), Lut (Texture2D), LutSampler (SamplerState),\r\n//           LutSize (Float, örn 32), Contribution (Float 0..1)\r\n// Çıkış: Out (Vector3)\r\n\r\nfloat w = LutSize * LutSize;\r\nfloat h = LutSize;\r\nfloat3 scaleOffset = float3(1.0 / w, 1.0 / h, h - 1.0);\r\n\r\nfloat3 uvw = saturate(In);\r\nuvw.z *= scaleOffset.z;                 // hangi dilim\r\nfloat shift = floor(uvw.z);\r\nuvw.xy = uvw.xy * scaleOffset.z * scaleOffset.xy + scaleOffset.xy * 0.5; // piksel merkezi düzeltmesi\r\nuvw.x += shift * scaleOffset.y;         // dilime kaydır\r\n\r\nfloat3 sliceA = SAMPLE_TEXTURE2D_LOD(Lut.tex, LutSampler.samplerstate, uvw.xy, 0.0).rgb;\r\nfloat3 sliceB = SAMPLE_TEXTURE2D_LOD(Lut.tex, LutSampler.samplerstate, uvw.xy + float2(scaleOffset.y, 0.0), 0.0).rgb;\r\nfloat3 graded = lerp(sliceA, sliceB, uvw.z - shift); // iki dilim arası blend\r\n\r\nOut = lerp(In, graded, Contribution);   // katkı miktarı"
}

